        "ch31.tc_type":      {"+type": "scalar", "+channel": "$(P)Ti31TCType.VAL",       "+trigger": "*"},
        "ch31.filter":       {"+type": "scalar", "+channel": "$(P)Ti31Filter.VAL",       "+trigger": "*"},
        "ch31.open_detect":  {"+type": "scalar", "+channel": "$(P)Ti31OpenTCDetect.VAL", "+trigger": "*"}
    }
}
